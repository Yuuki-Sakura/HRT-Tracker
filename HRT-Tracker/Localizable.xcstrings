            "value" : "重要提示"
          }
        }
      }
    },
    "disclaimer.limitation.1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Individual variability is not modeled: liver function, SHBG, age, body fat, and concurrent medications may alter bioavailability and rate constants."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "個人差はモデル化されていません：肝機能、SHBG、年齢、体脂肪、併用薬がバイオアベイラビリティと速度定数を変える可能性があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未建模个体差异：肝功能、SHBG、年龄、体脂、合用药物等可能改变生物利用度和速率常数。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未建模個體差異：肝功能、SHBG、年齡、體脂、合用藥物等可能改變生物利用度和速率常數。"
          }
        }
      }
    },
    "disclaimer.limitation.2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gel area/loading nonlinearity is not reflected in the current model."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ジェルの面積/負荷の非線形性は現在のモデルに反映されていません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "凝胶的涂抹面积/负荷非线性未在当前模型中体现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "凝膠的塗抹面積/負荷非線性未在當前模型中體現。"
          }
        }
      }
    },
    "disclaimer.limitation.3" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Injection solvent/volume effects on depot absorption rate are not explicitly parameterized."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注射溶媒/容量がデポー吸収速度に与える影響は明示的にパラメータ化されていません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注射溶剂/体积对库室吸收速率的影响未显式参数化。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注射溶劑/體積對庫室吸收速率的影響未顯式參數化。"
          }
        }
      }
    },
    "disclaimer.limitation.4" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oral/sublingual models only simulate free E2; estrone and its sulfate reservoir effects are not included."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経口/舌下モデルは遊離E2のみをシミュレートします。エストロンとその硫酸エステルの貯蔵効果は含まれていません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "口服/舌下模型仅模拟游离 E2；雌酮及其硫酸酯的储库效应未纳入。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "口服/舌下模型僅模擬游離 E2；雌酮及其硫酸酯的儲庫效應未納入。"
          }
        }
      }
    },
    "disclaimer.limitation.5" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cross-route AUC comparisons have limited validity; AUC is best used for within-route relative comparisons."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経路間のAUC比較は限定的な有効性です。AUCは同一経路内の相対的な比較に最適です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "跨路由 AUC 比较有效性有限；AUC 更适合同一给药途径内的相对比较。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "跨路由 AUC 比較有效性有限；AUC 更適合同一給藥途徑內的相對比較。"
          }
        }
      }
    },
