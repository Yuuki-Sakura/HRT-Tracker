    "modal.estimate.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app provides theoretical estimates based on pharmacokinetic models and cannot replace actual blood tests. Absorption and metabolism may vary over time for the same individual."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本アプリは薬物動態モデルに基づく理論上の推定値のみを提供しており、実際の血液検査の代わりにはなりません。同一個人でも時期により吸収・代謝が変化する可能性があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本软件仅依据药代动力学模型提供理论估算值，无法替代真实的血液检测。同一个体在不同时期的吸收代谢情况也可能发生变化。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本軟體僅依據藥代動力學模型提供理論估算值，無法替代真實的血液檢測。同一個體在不同時期的吸收代謝情況也可能發生變化。"
          }
        }
      }
    },
    "modal.estimate.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The only way to accurately know your blood concentration is through hospital blood tests. Always use hospital reports as the basis for medication adjustments, never rely solely on this app's estimates."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "血中濃度を正確に知る唯一の方法は、病院での血液検査です。投薬の調整は常に病院の検査報告を根拠とし、本アプリの推定値のみに頼らないでください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要准确了解您的血药浓度，唯一的途径是前往医院进行血检。请始终以医院检查报告作为调整用药的依据，切勿仅依赖本软件的估算值。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要準確了解您的血藥濃度，唯一的途徑是前往醫院進行血檢。請始終以醫院檢查報告作為調整用藥的依據，切勿僅依賴本軟體的估算值。"
          }
        }
      }
    },
