    "references.algorithm.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The pharmacokinetic algorithms, mathematical models, and parameters used in this simulation are derived directly from the HRT-Recorder-PKcomponent-Test repository. We strictly adhere to the PKcore.swift and PKparameter.swift logic provided by @LaoZhong-Mihari, ensuring accuracy of the 3-compartment models, two-part depot kinetics, and sublingual absorption tiers."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本シミュレーションで使用される薬物動態アルゴリズム、数学モデル、パラメータは、HRT-Recorder-PKcomponent-Testリポジトリから直接派生しています。@LaoZhong-Mihariが提供するPKcore.swiftおよびPKparameter.swiftのロジックに厳密に従い、3コンパートメントモデル、二相性デポ動態、舌下吸収ティアの精度を確保しています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本模拟中使用的药代动力学算法、数学模型与相关参数，直接来源于 HRT-Recorder-PKcomponent-Test 仓库。我们严格遵循 @LaoZhong-Mihari 提供的 PKcore.swift 与 PKparameter.swift 中的逻辑，确保三室模型、双相肌注库房动力学以及舌下吸收分层等的精度。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本模擬中使用的藥代動力學演算法、數學模型與相關參數，直接來源於 HRT-Recorder-PKcomponent-Test 倉庫。我們嚴格遵循 @LaoZhong-Mihari 提供的 PKcore.swift 與 PKparameter.swift 中的邏輯，確保三室模型、雙相肌注庫房動力學以及舌下吸收分層等的精度。"
          }
        }
      }
    },
