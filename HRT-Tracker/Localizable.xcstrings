    "modal.gaht.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your current estimated E2 level falls within the GAHT (Gender-Affirming Hormone Therapy) target range of 100–200 pg/mL, as recommended by the WPATH Standards of Care Version 8 (SOC8)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の推定E2レベルは、WPATH Standards of Care Version 8（SOC8）が推奨するGAHT（性別適合ホルモン療法）の目標範囲 100〜200 pg/mL 内にあります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前估算的 E2 水平处于 GAHT（性别肯定激素治疗）的目标范围 100–200 pg/mL 内，该范围参考自 WPATH 关怀标准第八版（SOC8）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目前估算的 E2 水平處於 GAHT（性別肯定荷爾蒙治療）的目標範圍 100–200 pg/mL 內，該範圍參考自 WPATH 關懷標準第八版（SOC8）。"
          }
        }
      }
    },
