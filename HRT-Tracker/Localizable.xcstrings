    "disclaimer.body.1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is designed solely as a personal tracking and estimation tool. It is NOT a medical device, and the pharmacokinetic simulation results do NOT constitute medical advice, diagnosis, or treatment recommendations."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは個人的な記録・推定ツールとしてのみ設計されています。医療機器ではなく、薬物動態シミュレーションの結果は医学的助言、診断、治療推奨を構成するものではありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HRT Tracker 不提供医学建议。尽管 HRT Tracker 包含一些医学相关的内容，但不保证其准确性或时效性。可能无法完全适用于您的具体情况。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本應用程式僅作為個人記錄和估算工具，並非醫療設備。藥代動力學模擬結果不構成醫療建議、診斷或治療方案。"
          }
        }
      }
    },
    "disclaimer.body.2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All hormone therapy decisions should be made in consultation with a qualified healthcare provider. Never adjust your medication dosage based solely on this app's output."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのホルモン療法に関する決定は、資格のある医療提供者と相談の上で行ってください。このアプリの出力のみに基づいて薬の投与量を調整しないでください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "医学信息仅供参考，不能替代具备资质的医务人员的诊断或治疗建议。即使内容准确无误，也可能不适用于您的健康状况。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有激素治療決策均應在合格醫療人員的指導下進行。切勿僅根據本應用程式的輸出結果自行調整藥物劑量。"
          }
        }
      }
    },
    "disclaimer.body.3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The pharmacokinetic models used are based on published literature and population-average parameters. Individual responses may vary significantly due to genetics, liver function, body composition, concurrent medications, and other factors."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用されている薬物動態モデルは公開された文献と集団平均パラメータに基づいています。遺伝、肝機能、体組成、併用薬などの要因により、個人の反応は大きく異なる場合があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若有任何健康疑虑，请咨询具备资质的医务人员。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所用藥代動力學模型基於已發表文獻和群體平均參數。由於遺傳、肝功能、體脂比例、合用藥物等因素，個體實際反應可能存在較大差異。"
          }
        }
      }
    },
