          }
        }
      }
    },
    "inj.guide.safety" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not use if at high risk for breast cancer or with severe liver disease!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "乳がん高リスク者・重度肝障害のある方は使用しないでください！"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "乳腺癌高风险者、重度肝障碍患者请勿使用！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "乳腺癌高風險者、重度肝障礙患者請勿使用！"
          }
        }
      }
    },
