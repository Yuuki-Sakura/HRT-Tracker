        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与雌激素合用时，10 mg/天已可最大程度抑制睾酮"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "與雌激素合用時，10 mg/天已可最大程度抑制睪酮"
          }
        }
      }
