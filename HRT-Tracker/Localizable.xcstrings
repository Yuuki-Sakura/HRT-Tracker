            "value" : "环戊丙酸雌二醇：每 7 天 5–6 mg / 每 14 天 10–12 mg"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "環戊丙酸雌二醇：每 7 天 5–6 mg / 每 14 天 10–12 mg"
          }
        }
      }
    },
    "inj.guide.dosage_ev" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estradiol Valerate: 5 mg every 5-7 days / 10 mg every 1-2 weeks"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "吉草酸エストラジオール：5〜7日ごとに5 mg / 1〜2週ごとに10 mg"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "戊酸雌二醇：每 5–7 天 5 mg / 每 1–2 周 10 mg"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "戊酸雌二醇：每 5–7 天 5 mg / 每 1–2 週 10 mg"
          }
        }
      }
    },
    "inj.guide.dosage_title" : {
      "extractionState" : "manual",
      "localizations" : {
