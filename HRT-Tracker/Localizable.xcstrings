    "dose.guide.cpa_hint.combo" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "With estrogen, 10 mg/day achieves maximum testosterone suppression"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エストロゲンとの併用時、10 mg/日でテストステロンの最大抑制が可能"
