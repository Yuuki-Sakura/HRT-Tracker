    "input.sublingual.instructions" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Place the tablet under your tongue and hold without swallowing. A higher tier means more mucosal absorption."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "錠剤を舌下に置き、飲み込まないでください。高い段階ほど粘膜吸収が多くなります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将药片置于舌下，不要吞咽。档位越高，黏膜吸收比例越大。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將藥片置於舌下，不要吞嚥。檔位越高，黏膜吸收比例越大。"
          }
        }
      }
    },
