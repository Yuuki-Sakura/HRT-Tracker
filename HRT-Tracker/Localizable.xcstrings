        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WPATH SOC8 recommends ≤10 mg/day. 10 mg/day with estrogen fully suppresses testosterone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WPATH SOC8では≤10 mg/日を推奨。エストロゲン併用で10 mg/日でテストステロンを完全に抑制。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
