    "input.gel.site.scrotalNote" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrotal application significantly increases absorption (~5×). The PK model uses F=0.25 (vs 0.05 for other sites) based on Premoli et al. (2005)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "陰嚢への塗布は吸収率を大幅に増加させます（約5倍）。PKモデルはPremoli et al. (2005)に基づきF=0.25（他部位は0.05）を使用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "阴囊涂抹会显著增加吸收率（约5倍）。PK 模型基于 Premoli et al. (2005) 使用 F=0.25（其他部位为 0.05）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "陰囊塗抹會顯著增加吸收率（約5倍）。PK 模型基於 Premoli et al. (2005) 使用 F=0.25（其他部位為 0.05）。"
          }
        }
      }
    },
