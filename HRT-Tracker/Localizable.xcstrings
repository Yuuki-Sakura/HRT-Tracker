    "inj.guide.note_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open ampoules correctly to avoid glass cuts, bottle shattering, or glass fragments entering the medication."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アンプルは正しい方法で開けてください。ガラスで怪我をしたり、瓶が割れたり、微小なガラス片が薬液に混入するのを防ぐためです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请以正确的方式打开安瓿瓶，以避免被玻璃划伤 / 使瓶子碎裂 / 使微小的玻璃碎渣混入药水。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請以正確的方式打開安瓿瓶，以避免被玻璃劃傷 / 使瓶子碎裂 / 使微小的玻璃碎渣混入藥水。"
          }
        }
      }
    },
    "inj.guide.note_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not inject at the same site repeatedly."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同じ部位に繰り返し注射しないでください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请勿重复注入同一位置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請勿重複注入同一位置。"
          }
        }
      }
    },
    "inj.guide.note_3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid blood vessels carefully. Risk of embolism!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "血管を避けてください。血管を塞栓する恐れがあります！"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小心避开血管。可能栓塞血管！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小心避開血管。可能栓塞血管！"
          }
        }
      }
    },
    "inj.guide.note_4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid nerves carefully. For intramuscular injection, inject in safe areas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "神経を避けてください。筋肉注射の場合は安全な部位に注射してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小心避开神经。若进行肌肉注射，在安全区域内注射。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小心避開神經。若進行肌肉注射，在安全區域內注射。"
          }
        }
      }
    },
    "inj.guide.note_5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Since the medication is oil-based, use 18G needle (pink) to draw and 23G/25G needle (blue) to inject."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "薬品は油性のため、12号針（ピンク、18G）で薬品を吸引し、6号針（青、23G/25G）で注射することを推奨します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由于药品为油性，建议使用 12 号针头（粉，18G）抽取药品，6 号针头（蓝，23G / 25G）注射。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由於藥品為油性，建議使用 12 號針頭（粉，18G）抽取藥品，6 號針頭（藍，23G / 25G）注射。"
          }
        }
      }
    },
    "inj.guide.note_6" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick needle insertion and using a new needle after drawing helps reduce pain."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "素早い穿刺と薬液吸引後に新しい針で注射することで痛みの軽減に役立ちます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速进针和抽药完毕后使用新的针头注射有助于缓解疼痛。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速進針和抽藥完畢後使用新的針頭注射有助於緩解疼痛。"
          }
        }
      }
    },
    "inj.guide.note_7" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For self-injection, use the vastus lateralis (outer upper third of thigh) or deltoid (vaccination site)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自己注射には外側広筋（大腿の外側上部3分の1）と三角筋（ワクチン接種部位）の使用を推奨します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自行注射建议使用股外侧肌（大腿三分之一中段斜外上方）和三角肌（打疫苗的位置）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自行注射建議使用股外側肌（大腿三分之一中段斜外上方）和三角肌（打疫苗的位置）。"
          }
        }
      }
    },
    "inj.guide.note_8" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you feel severe pain or see significant blood return when inserting the needle, remove it immediately, use a new needle, and change injection site."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注射針を挿入した際に激しい痛みを感じたり、大量の血液が逆流した場合は、直ちに針を抜き、新しい針に交換して注射部位を変更してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您在插入注射针头时感到剧烈疼痛或看到大量血液回流，请立即拔出针头，更换新的针头并更换注射部位。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您在插入注射針頭時感到劇烈疼痛或看到大量血液回流，請立即拔出針頭，更換新的針頭並更換注射部位。"
          }
        }
      }
    },
    "inj.guide.note_9" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If there is more bleeding than usual after injection (but it can be stopped), this is normal. Don't panic."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "注射後に通常より多い出血があっても（止められる場合）、正常な現象ですので慌てないでください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果在某次注射结束后有较以往更多出血（但可以止住），属于正常现象，请不要惊慌。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果在某次注射結束後有較以往更多出血（但可以止住），屬於正常現象，請不要驚慌。"
          }
        }
      }
    },
