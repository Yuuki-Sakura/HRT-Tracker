          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WPATH SOC8 建議 ≤10 mg/天。與雌激素聯用 10 mg/天即可完全抑制睪酮。"
          }
        }
      }
    },
